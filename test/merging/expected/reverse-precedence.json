{
  "application": {
    "environment": "production",
    "name": "my-app",
    "port": 8080,
    "version": "1.0.0"
  },
  "database": {
    "host": "localhost",
    "pool": {
      "max": 20,
      "min": 5
    },
    "port": 5432,
    "ssl": false,
    "user": "app_user"
  },
  "features": {
    "auth": true,
    "cache": false,
    "monitoring": true
  },
  "logging": {
    "format": "text",
    "level": "info",
    "output": "stdout"
  },
  "secrets": {
    "api_key": "prod-key-123"
  }
}

